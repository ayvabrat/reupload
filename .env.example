VK_ACCESS_TOKEN=your_vk_token_here
# Админка /admin (логин/пароль; по умолчанию admin / 324581)
ADMIN_USER=admin
ADMIN_PASSWORD=324581
# Fallback Telegram (основные токен и chat_id задаются в веб-панели → data/user_settings/{id}.json)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DB_PATH=data/database.db
EXPORT_DIR=data/exports
LOG_LEVEL=INFO
DEFAULT_MAX_RESULTS=500
DEFAULT_CHECK_INTERVAL=60
REQUEST_TIMEOUT=15
VK_RATE_LIMIT=0.34
RUTUBE_RATE_LIMIT=1.0
# GigaChat (опционально): ключ Authorization Basic из кабинета developers.sber.ru
GIGACHAT_CLIENT_ID=
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false
GIGACHAT_DELAY_SEC=1.2
# true = не вызывать чат GigaChat, только локальная эвристика (быстро, без отказов API)
GIGACHAT_LOCAL_ONLY=false
# Веб-панель (python main.py serve)
WEB_API_HOST=127.0.0.1
WEB_API_PORT=8765
# Доступ к панели: непустой WEB_AUTH_USER включает логин (HTTP Basic). Смените пароль на проде.
WEB_AUTH_USER=admin
WEB_AUTH_PASSWORD=123456
WEB_AUTH_ALLOW_HEALTH=true
# CORS: для домена сайта через запятую (пусто = разрешить всем). Пример: https://rbx.mom,https://www.rbx.mom
WEB_CORS_ORIGINS=
# К поиску добавляется шаблон перезаливов ШГШ (расширяет охват). Отключить: SHGSH_TEMPLATE_MERGE=false
SHGSH_TEMPLATE_MERGE=true
# Список через запятую; пусто = встроенный шаблон из config
SHGSH_KEYWORDS_TEMPLATE=
# Не звать GigaChat, если сработала жёсткая эвристика (быстрее)
GIGACHAT_SKIP_LLM_ON_STRONG_HEURISTIC=true
# Параллельные запросы к VK/Rutube по разным ключам (веб: поле «Потоков API» переопределяет)
SCAN_FETCH_WORKERS=8
# Параллельные вызовы GigaChat при режиме «во время парса»
GIGACHAT_PARALLEL_WORKERS=3
